{
  "name": "@orca-so/whirlpools",
  "version": "4.0.0",
  "description": "Orca's high-level typescript sdk to interact with Orca's on-chain Whirlpool program.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "../../LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --sourcemap",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@orca-so/whirlpools-core": "workspace:*"
  },
  "peerDependencies": {
    "@solana/kit": "^5.0.0",
    "@solana-program/memo": "^0.8.0",
    "@solana-program/system": "^0.8.1",
    "@solana-program/token": "^0.6.0",
    "@solana-program/token-2022": "^0.5.0",
    "@solana/sysvars": "^3.0.3"
  },
  "optionalDependencies": {
    "@orca-so/tx-sender": "workspace:*",
    "@orca-so/whirlpools-client": "workspace:*"
  },
  "devDependencies": {
    "@solana/kit": "^5.0.0",
    "solana-bankrun": "^0.4.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orca-so/whirlpools.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "keywords": [
    "solana",
    "crypto",
    "defi",
    "dex",
    "amm"
  ],
  "author": "team@orca.so",
  "bugs": {
    "url": "https://github.com/orca-so/whirlpools/issues"
  },
  "homepage": "https://orca.so"
}
